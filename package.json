{
    "name": "open-model-selector",
    "version": "0.1.0",
    "description": "A generic, OpenAI-compatible model selector component for React.",
    "main": "./dist/index.js",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.js"
        },
        "./styles.css": "./dist/styles.css"
    },
    "files": [
        "dist",
        "README.md"
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/sethbang/open-model-selector.git"
    },
    "bugs": {
        "url": "https://github.com/sethbang/open-model-selector/issues"
    },
    "homepage": "https://github.com/sethbang/open-model-selector#readme",
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "lint": "tsc",
        "prepublishOnly": "npm run build"
    },
    "keywords": [
        "openai",
        "react",
        "model-selector",
        "ui",
        "llm",
        "ai"
    ],
    "author": "Seth Bangert",
    "license": "MIT",
    "peerDependencies": {
        "react": ">=18",
        "react-dom": ">=18"
    },
    "devDependencies": {
        "@radix-ui/react-dialog": "^1.1.15",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "tsup": "^8.0.0",
        "typescript": "^5.0.0"
    },
    "dependencies": {
        "@radix-ui/react-dropdown-menu": "^2.1.16",
        "@radix-ui/react-hover-card": "^1.1.15",
        "@radix-ui/react-popover": "^1.1.15",
        "@radix-ui/react-slot": "^1.2.4",
        "cmdk": "^1.1.1"
    }
}
