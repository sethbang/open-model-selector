# ─────────────────────────────────────────────────────────────────────────────
# open-model-selector  —  Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
#
# Copy this file to .env and fill in the keys you need:
#   cp .env.example .env
#
# ALL keys are OPTIONAL. They are only used for:
#   • Live provider Storybook stories  (npm run storybook)
#   • The provider snapshot capture script  (node scripts/capture-provider-snapshots.cjs)
#
# .storybook/main.ts reads the raw KEY names below from .env and re-exposes
# them as STORYBOOK_* via Vite's `define` config (e.g. OPENAI_API_KEY →
# import.meta.env.STORYBOOK_OPENAI_KEY). You do NOT need to add a VITE_ or
# STORYBOOK_ prefix yourself.
# ─────────────────────────────────────────────────────────────────────────────

# ── Model-aggregator providers ──────────────────────────────────────────────

# OpenRouter  (https://openrouter.ai)
OPENROUTER_API_KEY=

# ── Direct-vendor providers ─────────────────────────────────────────────────

# OpenAI  (https://platform.openai.com)
OPENAI_API_KEY=

# Mistral AI  (https://console.mistral.ai)
MISTRAL_API_KEY=

# Google AI Studio / Gemini  (https://aistudio.google.com)
GOOGLE_AI_API_KEY=

# DeepSeek  (https://platform.deepseek.com)
DEEPSEEK_API_KEY=

# ── Inference-infra providers ───────────────────────────────────────────────

# Together AI  (https://api.together.xyz)
TOGETHER_API_KEY=

# Groq  (https://console.groq.com)
GROQ_API_KEY=

# Cerebras  (https://cloud.cerebras.ai)
CEREBRAS_API_KEY=

# Nvidia NIM  (https://build.nvidia.com)
NVIDIA_API_KEY=

# SambaNova  (https://cloud.sambanova.ai)
SAMBANOVA_API_KEY=

# ── Specialty / multi-modal providers ───────────────────────────────────────

# Venice AI  (https://venice.ai)  — multi-type models (text, image, etc.)
VENICE_API_KEY=

# ── Gateway / proxy providers ──────────────────────────────────────────────

# Helicone AI Gateway  (https://helicone.ai)
HELICONE_API_KEY=

# Vercel AI Gateway  (https://sdk.vercel.ai/)
VERCEL_API_KEY=
