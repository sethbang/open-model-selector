{
    "name": "open-model-selector",
    "version": "0.1.0",
    "description": "A generic, OpenAI-compatible model selector component for React.",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        },
        "./styles.css": "./dist/styles.css"
    },
    "files": [
        "dist",
        "README.md"
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/sethbang/open-model-selector.git"
    },
    "bugs": {
        "url": "https://github.com/sethbang/open-model-selector/issues"
    },
    "homepage": "https://github.com/sethbang/open-model-selector#readme",
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "lint": "tsc",
        "prepublishOnly": "npm run build"
    },
    "keywords": [
        "openai",
        "react",
        "model-selector",
        "ui",
        "llm",
        "ai"
    ],
    "author": "Seth Bang",
    "license": "MIT",
    "type": "module",
    "sideEffects": [
        "*.css"
    ],
    "peerDependencies": {
        "react": "^18.0.0 || ^19.0.0",
        "react-dom": "^18.0.0 || ^19.0.0",
        "@radix-ui/react-dropdown-menu": "^2.0.0",
        "@radix-ui/react-hover-card": "^1.0.0",
        "@radix-ui/react-popover": "^1.0.0",
        "@radix-ui/react-slot": "^1.0.0",
        "cmdk": "^1.0.0"
    },
    "peerDependenciesMeta": {
        "@radix-ui/react-dropdown-menu": {
            "optional": false
        },
        "@radix-ui/react-hover-card": {
            "optional": false
        },
        "@radix-ui/react-popover": {
            "optional": false
        },
        "@radix-ui/react-slot": {
            "optional": false
        },
        "cmdk": {
            "optional": false
        }
    },
    "devDependencies": {
        "@radix-ui/react-dialog": "^1.1.15",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "tsup": "^8.5.1",
        "typescript": "^5.9.3"
    }
}