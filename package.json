{
  "name": "open-model-selector",
  "version": "0.3.0",
  "description": "A generic, OpenAI-compatible model selector component for React.",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./utils": {
      "import": {
        "types": "./dist/utils.d.ts",
        "default": "./dist/utils.js"
      },
      "require": {
        "types": "./dist/utils.d.cts",
        "default": "./dist/utils.cjs"
      }
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sethbang/open-model-selector.git"
  },
  "bugs": {
    "url": "https://github.com/sethbang/open-model-selector/issues"
  },
  "homepage": "https://github.com/sethbang/open-model-selector#readme",
  "scripts": {
    "prebuild": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build",
    "preversion": "npm run typecheck && npm run test && npm run build",
    "version": "node scripts/check-changelog.cjs",
    "postversion": "git push && git push --tags",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "lint": "eslint src",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --max-warnings=0",
      "prettier --write"
    ],
    "*.{css,md,json,yml,yaml}": [
      "prettier --write"
    ]
  },
  "keywords": [
    "openai",
    "openai-api",
    "venice",
    "venice-ai",
    "openrouter",
    "react",
    "model-selector",
    "selector",
    "combobox",
    "dropdown",
    "components",
    "radix",
    "cmdk",
    "typescript",
    "ui",
    "a11y",
    "accessible",
    "dark-mode",
    "llm",
    "ai",
    "gpt"
  ],
  "author": "Seth Bang",
  "license": "MIT",
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "peerDependencies": {
    "@radix-ui/react-popover": "^1.1.15",
    "cmdk": "^1.1.1",
    "react": "^18.0.0 || ^19.2.5",
    "react-dom": "^18.0.0 || ^19.2.5"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.1.2",
    "@eslint/js": "^9.39.4",
    "@radix-ui/react-popover": "^1.1.15",
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/addon-onboarding": "^10.3.5",
    "@storybook/addon-vitest": "^10.3.5",
    "@storybook/react-vite": "^10.3.5",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitest/browser-playwright": "^4.1.4",
    "@vitest/coverage-v8": "^4.1.4",
    "cmdk": "^1.1.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "lint-staged": "^16.4.0",
    "playwright": "^1.59.1",
    "prettier": "^3.8.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "storybook": "^10.3.5",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
